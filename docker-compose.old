version: "3.9"

services:

  openmetadata-mysql:
    image: mysql:8.0
    container_name: openmetadata_mysql
    restart: unless-stopped
    environment:
      MYSQL_ROOT_PASSWORD: openmetadata_root_pass
      MYSQL_DATABASE: openmetadata_db
      MYSQL_USER: openmetadata_user
      MYSQL_PASSWORD: openmetadata_pass
    ports:
      - "3306:3306"
    command: --default-authentication-plugin=mysql_native_password
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 10s
      retries: 5
      start_period: 30s

  elasticsearch:
    image: docker.elastic.co/elasticsearch/elasticsearch:8.10.2
    container_name: elasticsearch
    restart: unless-stopped
    environment:
      discovery.type: single-node
      xpack.security.enabled: "false"
      ES_JAVA_OPTS: "-Xms512m -Xmx512m"
    ports:
      - "9200:9200"

  openmetadata-server:
    image: openmetadata/server:1.4.3
    container_name: openmetadata_server
    restart: always
    depends_on:
      openmetadata-mysql:
        condition: service_healthy
      elasticsearch:
        condition: service_started
    ports:
      - "8585:8585"
    environment:
      OPENMETADATA_SERVER_HOST: 0.0.0.0
      SERVER_PORT: 8585

      # 🔥 CONTROL DE MEMORIA (CLAVE)
      JAVA_OPTS: "-Xms512m -Xmx1024m"

      DB_DRIVER_CLASS: com.mysql.cj.jdbc.Driver
      DB_SCHEME: mysql
      DB_HOST: openmetadata-mysql
      DB_PORT: 3306
      DB_USER: openmetadata_user
      DB_USER_PASSWORD: openmetadata_pass
      OM_DATABASE: openmetadata_db
      DB_PARAMS: "useSSL=false&allowPublicKeyRetrieval=true"

      ELASTICSEARCH_HOST: elasticsearch
      ELASTICSEARCH_PORT: 9200